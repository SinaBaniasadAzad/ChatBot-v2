# ---- DeepSeek API ----
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# ---- Behavior ----
# حداکثر تعداد سوال تکمیلی که چت‌بات می‌تواند بپرسد
MAX_QUESTIONS=2
# دمای مدل برای دسته‌بندی (پایین = پایدارتر)
TEMPERATURE=0.0

# ---- Robustness ----
REQUEST_TIMEOUT=60
MAX_RETRIES=3

# ---- Interaction logging (ذخیرهٔ تیکت‌ها، سوال‌های تکمیلی، خروجی مدل) ----
# توجه: لاگ‌ها حاوی دادهٔ پرسنلی (PII) هستند؛ پوشهٔ logs/ در .gitignore است.
INTERACTION_LOG_ENABLED=true
INTERACTION_LOG_PATH=logs/interactions.jsonl

# ---- Ambiguity detection (اختیاری، نردبان تشدید) ----
# اگر روشن باشد، فقط برای موارد لب‌مرزی چند بار نمونه‌گیری می‌کند (self-consistency)
ENABLE_SELF_CONSISTENCY=false
SELF_CONSISTENCY_SAMPLES=3
