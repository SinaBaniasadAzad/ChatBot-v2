# کپی کنید به .env:  cp .env.example .env   (فایل .env هرگز commit نمی‌شود)

# ---- DeepSeek (اجباری برای اجرای واقعی) ----
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-pro

# ---- رفتار ----
# MAX_QUESTIONS=2
# TEMPERATURE=0.0

# ---- Retrieval (سابقه + گِیتِ kNN) ----
# RETRIEVAL_ENABLED=true
# RETRIEVAL_K_DEMOS=6
# RETRIEVAL_PURITY_K=15
# RETRIEVAL_SIM_FLOOR=0.40
# KNN_DISAGREE_PURITY=0.80

# ---- Observability / Langfuse (self-hosted: deploy/langfuse) ----
# نبودِ کلیدها فقط ردیابی را خاموش می‌کند؛ سیستم بدونِ آن هم کار می‌کند.
OBSERVABILITY_ENABLED=true
LANGFUSE_HOST=http://localhost:8080
LANGFUSE_PUBLIC_KEY=pk-lf-ticket-triage-local
LANGFUSE_SECRET_KEY=sk-lf-babaed0f-7d5b-4034-be4f-25b83f1a7774
# production | evaluation | experiment | development
OBSERVABILITY_ENVIRONMENT=production
# LANGFUSE_SAMPLE_RATE=1.0

# ---- قیمت‌گذاری DeepSeek (دلار به‌ازای ۱M توکن — با نرخِ روز تأیید شود) ----
# DEEPSEEK_PRICE_INPUT_PER_1M=0.14
# DEEPSEEK_PRICE_CACHE_HIT_PER_1M=0.0028
# DEEPSEEK_PRICE_OUTPUT_PER_1M=0.28

# ---- صفِ بازبینیِ انسانی ----
# REVIEW_QUEUE_ENABLED=true
# REVIEW_DB_PATH=logs/review.db

# ---- لاگِ تعاملات (PII — داخلِ logs/ بماند) ----
# INTERACTION_LOG_ENABLED=true
# INTERACTION_LOG_PATH=logs/interactions.jsonl
