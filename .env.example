# =============================================================================
# Ticket Triage Chatbot — نمونهٔ کامل پیکربندی
# کپی کنید به .env و مقدارها را تنظیم کنید. «.env هرگز commit نمی‌شود» (.gitignore).
# همهٔ مقدارها اختیاری‌اند مگر DEEPSEEK_API_KEY.
# =============================================================================

# ---- LLM API (اجباری برای دسته‌بندی؛ بدونِ آن، ثبتِ دستی تیکت همچنان کار می‌کند) ----
# کلید DeepSeek از platform.deepseek.com — هرگز مقدار واقعی را در مخزن نگذارید.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# گزینهٔ جایگزین برای تست: OpenRouter (سازگار با OpenAI SDK)
#DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
#DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324

# ---- Behavior ----
# حداکثر تعداد سوال تکمیلی که چت‌بات می‌پرسد
MAX_QUESTIONS=2
# دمای مدل (پایین = پایدارتر)
TEMPERATURE=0.0

# ---- Robustness (فراخوانی DeepSeek) ----
# مهلت هر فراخوان (ثانیه). p95 دسته‌بندی ~۱۵s است؛ ۳۰ برای وب کافی است.
REQUEST_TIMEOUT=30
# تعداد تلاش‌ها روی خطاهای گذرا (شبکه/۵xx/429) با backoff نمایی + jitter
MAX_RETRIES=3
# مدارشکن: پس از این تعداد چرخهٔ ناموفقِ پیاپی، تا CB_COOLDOWN_SECONDS ثانیه
# بدون انتظار «۵۰۳ سرویس دسته‌بندی در دسترس نیست» برمی‌گردد (ثبت دستی فعال می‌ماند).
CB_FAILURE_THRESHOLD=3
CB_COOLDOWN_SECONDS=30
# سقف اتصال‌های همزمان HTTP به DeepSeek (بار اوج ~۱۰ فراخوان همزمان → ۱۶ کافی است)
LLM_MAX_CONNECTIONS=16

# ---- Datastore (SQLite/WAL — تیکت‌ها، شمارندهٔ پیگیری، لاگ تعاملات، جستجوی FTS) ----
# در Docker این مسیر داخل volume است: /data/app.db (در ایمیج تنظیم شده).
# مسیر نسبی، نسبت به ریشهٔ پروژه است.
APP_DB_PATH=data/app.db

# ---- Data retention / PII (اجرای خودکار روزانه + CLI: python -m scripts.db_maintenance) ----
RETENTION_ENABLED=true
# حذف کامل لاگ تعاملات (شامل متن تیکت — PII) پس از این تعداد روز. 0 = هرگز
INTERACTION_RETENTION_DAYS=90
# ناشناس‌سازی هویت تیکت‌ها (نام + کد پرسنلی → NULL) پس از این تعداد روز. 0 = هرگز
TICKET_ANONYMIZE_DAYS=365
# حذف کامل تیکت‌های قدیمی. 0 = هرگز (پیش‌فرض: فقط ناشناس‌سازی)
TICKET_DELETE_DAYS=0

# ---- Sessions (درون‌حافظه‌ای؛ الزام: دقیقاً یک worker در uvicorn) ----
# جلسه‌های گفتگوی بی‌حرکت پس از این مدت (دقیقه) پاک می‌شوند
SESSION_TTL_MINUTES=60

# ---- HTTP ----
# SPA از همین سرویس سرو می‌شود (هم‌مبدأ) → CORS پیش‌فرض خاموش است.
# فقط اگر UI از مبدأ دیگری صدا می‌زند، فهرست جداشده با کاما بدهید:
#CORS_ORIGINS=https://intranet.example.local
# توکن اندپوینت‌های ادمین (GET /api/tickets… با هدر X-Admin-Token). خالی = غیرفعال.
ADMIN_API_TOKEN=

# ---- Logging ----
# json (پیشنهادِ production — هر خط یک شیء JSON، مناسبِ journald/Docker) یا text (توسعه)
LOG_FORMAT=json
LOG_LEVEL=INFO
# لاگ تحلیلیِ تعاملات (در جدول interactions ذخیره می‌شود؛ حاوی PII — retention بالا را ببینید)
INTERACTION_LOG_ENABLED=true

# ---- Retrieval-augmented classification (اختیاری) ----
# نیازمند ایندکس (python -m scripts.build_retrieval_index) + نصب requirements-retrieval.txt
# (torch/FlagEmbedding، ~+۴GB RAM). اگر ایندکس/وابستگی نباشد خودکار غیرفعال می‌شود.
RETRIEVAL_ENABLED=true
#RETRIEVAL_INDEX_PATH=data/retrieval/index.npz
#RETRIEVAL_POOL_PATH=data/retrieval/tickets_clean.jsonl
#RETRIEVAL_K_DEMOS=6
#RETRIEVAL_PURITY_K=15
#RETRIEVAL_SIM_FLOOR=0.40
#KNN_DISAGREE_PURITY=0.80
#EVIDENCE_VERIFICATION=true

# ---- Ambiguity detection (اختیاری) ----
ENABLE_SELF_CONSISTENCY=false
SELF_CONSISTENCY_SAMPLES=3
